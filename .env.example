# Aplicação Django.
# Controla o modo de execução local, a chave secreta e os hosts liberados.
DEBUG=True
SECRET_KEY=sua-chave-secreta-gerada-aqui
ALLOWED_HOSTS=127.0.0.1,localhost

# Banco de dados.
# Define a conexão usada pelo projeto para persistir as informações.
DATABASE_URL=sqlite:///db.sqlite3

# IA dos informativos fiscais.
# Controla se a análise por IA estará ativa e como o pipeline será executado.
NEWS_AI_ENABLED=False
NEWS_AI_PROVIDER=openai
NEWS_AI_MODEL=gpt-4o-mini
NEWS_AI_TIMEOUT_SECONDS=45
NEWS_AI_PIPELINE_VERSION=v1
NEWS_AI_BATCH_SIZE=5

# Credenciais e endpoint do provider OpenAI.
# Informa a chave da API e, opcionalmente, organização, projeto e base URL customizada.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_ORG_ID=
OPENAI_PROJECT=
